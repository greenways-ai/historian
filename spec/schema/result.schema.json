{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://greenways-ai.github.io/historian/schema/result-1.0.json",
  "$defs":{
    "Position":{"type":"object","required":["line","column"],"properties":{"line":{"type":"integer","minimum":1},"column":{"type":"integer","minimum":1}},"additionalProperties":false},
    "Range":{"type":"object","required":["start_byte","end_byte","start","end"],"properties":{"start_byte":{"type":"integer","minimum":0},"end_byte":{"type":"integer","minimum":0},"start":{"$ref":"#/$defs/Position"},"end":{"$ref":"#/$defs/Position"}},"additionalProperties":false},
    "Hash":{"type":"string","pattern":"^[a-f0-9]{64}$"},
    "File":{"type":"object","required":["language","path","blob_oid","source_bytes"],"properties":{"language":{"type":"string","minLength":1},"path":{"type":"string","minLength":1},"blob_oid":{"type":"string","minLength":1},"namespace":{"type":"string","minLength":1},"imports":{"type":"array","items":{"type":"string"}},"source_bytes":{"type":"integer","minimum":0}},"additionalProperties":false},
    "Symbol":{"type":"object","required":["local_id","kind","name","range","selection_range","source_hash","structural_hash"],"properties":{"local_id":{"type":"string","minLength":1},"parent_local_id":{"type":"string","minLength":1},"kind":{"type":"string","pattern":"^(namespace|module|class|interface|protocol|record|type|function|method|macro|multimethod|variable|constant|field|test|language:.+)$"},"name":{"type":"string","minLength":1},"qualified_name":{"type":"string"},"range":{"$ref":"#/$defs/Range"},"selection_range":{"$ref":"#/$defs/Range"},"signature":{"type":"string"},"documentation":{"type":"string"},"modifiers":{"type":"array","items":{"type":"string"},"uniqueItems":true},"metadata":{"type":"object"},"source_hash":{"$ref":"#/$defs/Hash"},"structural_hash":{"$ref":"#/$defs/Hash"},"structure":{}},"additionalProperties":false},
    "Reference":{"type":"object","required":["kind","range","resolution","confidence"],"properties":{"kind":{"enum":["call","read","write","import","type","inheritance","implementation","macro"]},"range":{"$ref":"#/$defs/Range"},"source_symbol_local_id":{"type":"string"},"target_text":{"type":"string"},"target_qualified_name":{"type":"string"},"resolution":{"enum":["resolved","candidate","dynamic","unresolved"]},"confidence":{"type":"number","minimum":0,"maximum":1}},"additionalProperties":false},
    "Diagnostic":{"type":"object","required":["message","severity","range"],"properties":{"message":{"type":"string","minLength":1},"severity":{"enum":["error","warning","info"]},"range":{"$ref":"#/$defs/Range"},"code":{"type":"string"}},"additionalProperties":false},
    "AnalyzeResult":{"type":"object","required":["file","symbols","references","diagnostics"],"properties":{"file":{"$ref":"#/$defs/File"},"symbols":{"type":"array","items":{"$ref":"#/$defs/Symbol"}},"references":{"type":"array","items":{"$ref":"#/$defs/Reference"}},"diagnostics":{"type":"array","items":{"$ref":"#/$defs/Diagnostic"}}},"additionalProperties":false},
    "DescribeResult":{"type":"object","required":["name","version","protocol_versions","languages","extensions","capabilities","max_message_bytes","fingerprint"],"properties":{"name":{"type":"string","minLength":1},"version":{"type":"string"},"protocol_versions":{"type":"array","minItems":1,"items":{"type":"string"},"uniqueItems":true},"languages":{"type":"array","minItems":1,"items":{"type":"string"},"uniqueItems":true},"extensions":{"type":"array","items":{"type":"string"},"uniqueItems":true},"capabilities":{"type":"array","items":{"type":"string"},"uniqueItems":true},"max_message_bytes":{"type":"integer","minimum":1},"fingerprint":{"$ref":"#/$defs/Hash"}},"additionalProperties":false},
    "PingResult":{"type":"object","required":["ok"],"properties":{"ok":{"const":true}},"additionalProperties":false},
    "ShutdownResult":{"type":"object","required":["ok"],"properties":{"ok":{"const":true}},"additionalProperties":false}
  }
}
