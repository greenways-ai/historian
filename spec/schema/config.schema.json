{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Greenways Historian configuration",
  "type": "object",
  "required": ["history", "analyzers"],
  "properties": {
    "history": {
      "type": "object",
      "required": ["refs"],
      "properties": {
        "refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "includeMergedCommits": { "type": "boolean", "default": true }
      }
    },
    "analyzers": { "type": "object", "minProperties": 1 }
  },
  "additionalProperties": false
}
