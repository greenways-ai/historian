{
  "$schema": "./spec/schema/config.schema.json",
  "history": {
    "refs": ["HEAD"],
    "includeMergedCommits": true
  },
  "analyzers": {
    "clojure": {
      "command": ["bb", "-cp", "analyzers/clojure/src", "-m", "greenways-historian.analyzer"],
      "extensions": [".clj", ".bb"]
    },
    "javascript": {
      "command": ["bun", "analyzers/typescript/src/analyzer.js"],
      "extensions": [".js", ".jsx", ".mjs", ".cjs"]
    },
    "typescript": {
      "command": ["bun", "analyzers/typescript/src/analyzer.js"],
      "extensions": [".ts", ".tsx", ".d.ts"]
    },
    "python": {
      "command": ["python3", "analyzers/python/src/analyzer.py"],
      "extensions": [".py", ".pyi", ".pyw"]
    }
  }
}
